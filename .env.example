# ============================================================
# Job Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub!
# ============================================================

# ── Anthropic (Claude AI) ─────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── LinkedIn Session Cookie ───────────────────────────────
# How to get it:
#   1. Login to LinkedIn in Chrome
#   2. Open DevTools → Application → Cookies → linkedin.com
#   3. Copy the value of the 'li_at' cookie
LI_AT=AQEDATxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail SMTP) ────────────────────────────────────
# Use a Gmail App Password (NOT your real Gmail password):
#   1. Go to myaccount.google.com → Security → 2-Step Verification
#   2. At the bottom: App passwords → Create for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Approval Server ───────────────────────────────────────
# URL where the approval server is accessible.
# For local use: http://localhost:8080
# For remote use: your ngrok or VPS URL, e.g. https://abc123.ngrok.io
APPROVAL_BASE_URL=http://localhost:8080
